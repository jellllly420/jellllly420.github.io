---
import { formatDateShort } from '@/utils/date';

interface Props {
  title: string;
  href: string;
  date: Date;
  tag?: string;
  excerpt?: string;
}

const { title, href, date, tag, excerpt } = Astro.props;
---

<a href={href} class="featured">
  {tag && <span class="featured-tag">{tag}</span>}
  <h2 class="featured-title">{title}</h2>
  {excerpt && <p class="featured-excerpt">{excerpt}</p>}
  <time class="featured-date" datetime={date.toISOString()}>{formatDateShort(date)}</time>
</a>

<style>
  .featured {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    padding: 1rem 0 2rem;
    transition: transform var(--transition-base);
  }

  .featured:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

  .featured-tag {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background-color: var(--accent-subtle);
    border-radius: 999px;
    padding: 0.2em 0.75em;
    margin-bottom: 0.75rem;
    width: fit-content;
    transition: background-color var(--transition-base);
  }

  .featured-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    max-width: 700px;
    line-height: 1.3;
    margin-bottom: 0.6rem;
    transition: color var(--transition-base);
  }

  .featured:hover .featured-title {
    color: var(--accent);
  }

  .featured-excerpt {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 0.5rem;
    transition: color var(--transition-base);
  }

  .featured-date {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.75rem;
    transition: color var(--transition-base);
  }
</style>
