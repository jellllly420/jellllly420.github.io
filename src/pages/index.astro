---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Timeline from '@/components/react/Timeline';

const timelineEntries = [
  {
    year: 'Sep 2020 - Jun 2024',
    title: 'Undergraduate @ Peking University',
    subtitle: 'Information and Computing Science',
    details: '',
  },
  {
    year: 'Sep 2024 -',
    title: 'Master Student @ Peking University',
    subtitle: 'Computer Science and Technology',
    details: '',
  },
  {
    year: 'Dec 2024 - ',
    title: 'Visiting Student @ Zhongguancun National Laboratory',
    subtitle: 'Development of Asterinas Scheduler and RPLT toolchain',
    details: '',
  },
  {
    year: 'May 2025 - Sep 2025',
    title: 'Participator @ Open Source Software Supply Chain Promotion Plan',
    subtitle: 'Enhancement of RISC-V64 Support in Asterinas Kernel',
    details: '',
  },

  {
    year: 'Mar 2026 -',
    title: 'Software Engineer Intern @ Tencent WXG',
    subtitle: 'Development of Wechat Built-in AI Assistant',
    details: '',
  },
];
---

<BaseLayout
  title="Home"
  description="Jelly's personal website — technical musings, random thoughts, and other stuff."
>
  <div class="container">
    <section class="hero animate-in">
      <h1 class="hero-name">Jelly</h1>
      <p class="hero-tagline">Technical musings, random thoughts, and other stuff.</p>
      <div class="hero-links">
        <a href="https://github.com/jellllly420" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.linkedin.com/in/zejun-zhao-1b1463267/"
          target="_blank"
          rel="noopener"
          aria-label="LinkedIn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path></svg
          >
        </a>
        <a href="https://x.com/jellllly420" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path></svg
          >
        </a>
        <a href="mailto:jelly.zhao.42@gmail.com" aria-label="Email">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M22 7l-10 7L2 7"
            ></path></svg
          >
        </a>
        <a href="/feed.xml" aria-label="RSS">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M4 11a9 9 0 019 9"></path><path d="M4 4a16 16 0 0116 16"></path><circle
              cx="5"
              cy="19"
              r="1"
              fill="currentColor"></circle></svg
          >
        </a>
      </div>
    </section>
    <section class="timeline-section">
      <Timeline client:visible entries={timelineEntries} />
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
  }

  .hero-name {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 500px;
    margin: 0 auto;
  }

  .hero-links {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .hero-links a {
    color: var(--text-muted);
    transition:
      color 0.15s,
      transform 0.15s;
    display: flex;
    align-items: center;
  }

  .hero-links a:hover {
    color: var(--accent);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .timeline-section {
    padding: 2rem 0 4rem;
  }

  .section-heading {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 1.5rem;
  }
</style>
