---
import { getCollection, render } from 'astro:content';
import PostLayout from '@/layouts/PostLayout.astro';
import { sortByDate } from '@/utils/content';

export async function getStaticPaths() {
  const posts = await getCollection('travel');
  const sorted = sortByDate(posts);
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i + 1] ? { slug: sorted[i + 1].id, title: sorted[i + 1].data.title, basePath: '/travel' } : undefined,
      next: sorted[i - 1] ? { slug: sorted[i - 1].id, title: sorted[i - 1].data.title, basePath: '/travel' } : undefined,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  tags={post.data.tags}
  headings={headings}
  heroImage={post.data.heroImage}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>
