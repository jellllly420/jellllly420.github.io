---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Jelly — CS master student, systems programmer, open source contributor."
>
  <div class="container">
    <div class="about animate-in">
      <h1>About Me</h1>
      <div class="prose">
        <p>
          Hi, I'm <strong>Jelly</strong> (Zejun Zhao), a master student in Computer Science and Technology
          at Peking University. I received my bachelor's degree in Information and Computing Science from
          the same university in 2024.
        </p>
        <p>
          My interests lie in <strong>operating systems</strong> and <strong>AI agents</strong>. I
          love systems programming, vibe coding, and open source.
        </p>
        <p>
          Outside of work, I enjoy reading, watching movies, and traveling. This site is where I
          write about technical topics, share notes on media I consume, and document my trips.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about {
    padding: 3rem 0 4rem;
    max-width: 720px;
  }

  h1 {
    margin-bottom: 1.5rem;
  }
</style>
