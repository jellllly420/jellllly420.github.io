---
import { getCollection } from 'astro:content';
import ListingLayout from '@/layouts/ListingLayout.astro';
import CardGrid from '@/components/CardGrid.astro';
import Card from '@/components/Card.astro';
import { sortByDate } from '@/utils/content';

const posts = await getCollection('shelf');
const sorted = sortByDate(posts);
---

<ListingLayout title="Shelf" tagline="Books, movies, and other media.">
  <CardGrid>
    {
      sorted.map((post) => (
        <Card
          title={post.data.title}
          href={`/shelf/${post.id}`}
          date={post.data.date}
          tag={post.data.mediaType}
          excerpt={post.data.excerpt}
        />
      ))
    }
  </CardGrid>
</ListingLayout>
